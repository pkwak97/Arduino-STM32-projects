#include <Wire.h>
#include <Adafruit_PWMServoDriver.h>

// 모터 제어 핀 정의 (PCA9685 채널 번호)
#define Motor_L1_F_PIN 11  // 왼쪽 앞쪽 모터 전진
#define Motor_L1_B_PIN 10  // 왼쪽 앞쪽 모터 후진
#define Motor_L2_F_PIN 8   // 왼쪽 뒤쪽 모터 전진
#define Motor_L2_B_PIN 9   // 왼쪽 뒤쪽 모터 후진
#define Motor_R1_F_PIN 13  // 오른쪽 앞쪽 모터 전진
#define Motor_R1_B_PIN 12  // 오른쪽 앞쪽 모터 후진
#define Motor_R2_F_PIN 14  // 오른쪽 뒤쪽 모터 전진
#define Motor_R2_B_PIN 15  // 오른쪽 뒤쪽 모터 후진

// 하위 드라이버 칩 관련 매개변수
#define Bottom_Layer_Driver_ADDR 0x40

// PWM 주파수 정의
#define PWM_FREQUENCY 50 

// 버튼 핀 및 상태 정의
#define KEY_PIN 7
#define Press_KEY 0
#define Release_KEY 1

// 초음파 센서 핀 정의
#define TRIG_PIN 11
#define ECHO_PIN 12


enum MovementMode {
  STOP, FORWARD, BACKWARD, LEFT_FORWARD, RIGHT_FORWARD
};

enum AvoidState {
  NORMAL_DRIVE, EVADE_LEFT, PASS_FORWARD, RETURN_RIGHT
};

bool bCar_Switch = false;  
int BaseSpeed = 100;       // PID 제어의 기준 속도
float Distance = 0.0;  
int obstacleCounter = 0;
// PID 제어 관련 변수 설정 (중복 선언 제거)
float TargetDistance = 50.0; 
float Kp = 4.5;              

AvoidState currentAvoidState = NORMAL_DRIVE;
Adafruit_PWMServoDriver pwm = Adafruit_PWMServoDriver(Bottom_Layer_Driver_ADDR);  
unsigned long stateStartTime = 0;

// 모터 스피드 맵핑 및 제어
void setMotorSpeed(uint16_t motor_forward_pin, uint16_t motor_backward_pin, int motor_speed) {
  motor_speed = map(motor_speed, -255, 255, -4095, 4095);
  if (motor_speed >= 0) {
    pwm.setPWM(motor_forward_pin, 0, motor_speed);
    pwm.setPWM(motor_backward_pin, 0, 0);
  } else {
    pwm.setPWM(motor_forward_pin, 0, 0);
    pwm.setPWM(motor_backward_pin, 0, -motor_speed);
  }
}

// 자동차 방향 전환 
void setCarMove(uint8_t Movement, int Speed) {  
  switch (Movement) {  
    case STOP:
      setMotorSpeed(Motor_L1_F_PIN, Motor_L1_B_PIN, 0);  
      setMotorSpeed(Motor_L2_F_PIN, Motor_L2_B_PIN, 0);  
      setMotorSpeed(Motor_R1_F_PIN, Motor_R1_B_PIN, 0);  
      setMotorSpeed(Motor_R2_F_PIN, Motor_R2_B_PIN, 0);  
      break;
    case FORWARD:  
      setMotorSpeed(Motor_L1_F_PIN, Motor_L1_B_PIN, Speed);  
      setMotorSpeed(Motor_L2_F_PIN, Motor_L2_B_PIN, Speed);  
      setMotorSpeed(Motor_R1_F_PIN, Motor_R1_B_PIN, Speed);  
      setMotorSpeed(Motor_R2_F_PIN, Motor_R2_B_PIN, Speed);  
      break;
    case BACKWARD:  
      setMotorSpeed(Motor_L1_F_PIN, Motor_L1_B_PIN, -Speed);  
      setMotorSpeed(Motor_L2_F_PIN, Motor_L2_B_PIN, -Speed);  
      setMotorSpeed(Motor_R1_F_PIN, Motor_R1_B_PIN, -Speed);  
      setMotorSpeed(Motor_R2_F_PIN, Motor_R2_B_PIN, -Speed);  
      break;
    case LEFT_FORWARD:
      setMotorSpeed(Motor_L1_F_PIN, Motor_L1_B_PIN, 0);
      setMotorSpeed(Motor_L2_F_PIN, Motor_L2_B_PIN, Speed);
      setMotorSpeed(Motor_R1_F_PIN, Motor_R1_B_PIN, Speed);
      setMotorSpeed(Motor_R2_F_PIN, Motor_R2_B_PIN, 0);
      break;
    case RIGHT_FORWARD:
      setMotorSpeed(Motor_L1_F_PIN, Motor_L1_B_PIN, Speed);
      setMotorSpeed(Motor_L2_F_PIN, Motor_L2_B_PIN, 0);
      setMotorSpeed(Motor_R1_F_PIN, Motor_R1_B_PIN, 0);
      setMotorSpeed(Motor_R2_F_PIN, Motor_R2_B_PIN, Speed);
      break;
  }  
}  

int getKeyState(uint8_t pin) {  
  if (digitalRead(pin) == LOW) {  
    delay(20);  
    if (digitalRead(pin) == LOW) {  
      while (digitalRead(pin) == LOW);  
      return Press_KEY;  
    }  
  }  
  return Release_KEY;  
}  

bool setCarSwitch() {
  if (getKeyState(KEY_PIN) == Press_KEY) {
    bCar_Switch = !bCar_Switch; 
    if (!bCar_Switch) {
      setCarMove(STOP, 0);
      currentAvoidState = NORMAL_DRIVE;
    }
    Serial.print("Car State: ");
    Serial.println(bCar_Switch ? "RUNNING" : "STOPPED");
  }
  return bCar_Switch;
}

float getDistance(int trigPin, int echoPin) {  
  pinMode(trigPin, OUTPUT); // 
  pinMode(echoPin, INPUT);
  
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);  
  delayMicroseconds(10);  
  digitalWrite(trigPin, LOW);  

  long duration = pulseIn(echoPin, HIGH, 25000); 
  float distance = (duration * 0.034 / 2);  
  
  if (distance <=0 || distance > 200.0) return 999.0; 
  //else if 안적어줘도 return 자체로 탈출!
  return distance;  
}  

void Advanced_Avoid_Control() {  
  Distance = getDistance(TRIG_PIN, ECHO_PIN);  
  unsigned long currentTime = millis();

  switch (currentAvoidState) {
    case NORMAL_DRIVE:
      Serial.print("일반 주행모드 거리: ");
      Serial.println(Distance);
      //수정했음 35 -> 10
      if (Distance <40.0) {
        obstacleCounter++;
        if(obstacleCounter >=3){
        currentAvoidState = EVADE_LEFT;
        stateStartTime = currentTime;
        obstacleCounter = 0;
        }
      } 
      else {
        obstacleCounter = 0;

        float error = Distance - 30.0;
        int finalSpeed = constrain(int(error * Kp), -255, 255);
        if (finalSpeed > 20) {
          setCarMove(FORWARD, finalSpeed);
        } 
        else {
          setCarMove(FORWARD,40);                                                                                                                                 
        }
      }
      break;

    case EVADE_LEFT:
      Serial.println("시퀀스 1단계: 좌대각 이동");
      setCarMove(LEFT_FORWARD, 140);

      if ((currentTime - stateStartTime >= 700) && (Distance > 45.0)) { //현재 시간 -기준시간
        currentAvoidState = PASS_FORWARD;  // 다음 단계로 진입
        stateStartTime = currentTime;    //현재시간을 기준시간으로 맞추고 다음 단계 진입! 
      }
      break;

    case PASS_FORWARD:
      Serial.println("시퀀스 2단계: 직진 추월");
      setCarMove(FORWARD, 100);
      
      if (currentTime - stateStartTime >= 800) {
        currentAvoidState = RETURN_RIGHT;  // 다음 단계로 진입 (수정됨)
        stateStartTime = currentTime;
      }
      break;

    case RETURN_RIGHT:
      Serial.println("시퀀스 3단계: 우대각 복귀");
      setCarMove(RIGHT_FORWARD, 160);     // 정의된 모션 상수로 변경
      
      if (currentTime - stateStartTime >= 700) {
        currentAvoidState = NORMAL_DRIVE;  // 모든 단계를 마친 후 일반 주행으로 복귀 (수정됨)
        stateStartTime = currentTime;
      }
      break;
}
}

void setup() {  
  Serial.begin(115200);
  Wire.begin();
  delay(500);
  pinMode(KEY_PIN, INPUT_PULLUP);
  pwm.begin();
  pwm.setPWMFreq(PWM_FREQUENCY);
  setCarMove(STOP, 0);
}  

void loop() {  
  if (setCarSwitch()) {  
    Advanced_Avoid_Control();  
    delay(20); 
  } else {  
    setCarMove(STOP, 0);  
  }  
}
